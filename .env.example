# LLM
ANTHROPIC_API_KEY=sk-ant-replace-me
ANTHROPIC_MODEL=claude-opus-4-5

# Sandbox
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MEMORY_MB=256
SANDBOX_CPU=0.5
SANDBOX_IMAGE=temper-sandbox-base:latest

# Database
DATABASE_PATH=./data/temper.db
SECRETS_MASTER_KEY=demo-only-32-bytes-replace-in-prod-xx

# Services
API_PORT=4000
UI_PORT=3000
RUNNER_PORT=5003
EGRESS_PROXY_PORT=5080

# Mock services
MOCK_SYSTEM_A_PORT=5001
MOCK_SYSTEM_B_PORT=5002
MOCK_SFTP_PORT=5022

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=integration-tasks

# Demo seed
DEMO_TENANT_ID=tenant-demo
DEMO_TENANT_NAME=Demo Tenant
DEMO_USER_EMAIL=demo@example.com
