  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/dockerode": "^3.3.0",
    "@types/node": "^22.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/ssh2-sftp-client": "^9.0.4",
    "better-sqlite3": "^11.3.0",
