{
  "name": "@temper/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "node --test --import tsx src/*.test.ts"
  },
  "dependencies": {
    "fastify": "^4.28.0",
    "@fastify/cors": "^9.0.1",
    "fastify-sse-v2": "^4.1.0",
    "@temper/shared": "workspace:*",
    "@temper/db": "workspace:*",
    "@temper/workflows": "workspace:*",
    "pg": "^8.21.0",
    "zod": "^3.23.8",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "tsx": "^4.19.0",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.20.0"
  }
}
